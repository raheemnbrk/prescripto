generator client {
  provider = "prisma-client-js"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password      String
  image         String   @default("")
  gender        String?
  dob           DateTime?
  role          Role     @default(PATIENT)
  phoneNumber   String?
  createdAt     DateTime @default(now())

  refreshTokens RefreshToken[]
  doctor        Doctor?
  appointments  Appointment[]
}

enum Role {
  PATIENT
  ADMIN
  DOCTOR
}

model RefreshToken {
  id         String   @id @default(cuid())
  token      String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  replacedBy String?

  createdAt  DateTime @default(now())
}

model Doctor {
  userId         String       @id
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  specialization String
  experience     Int
  fees           Float
  about          String
  degree         String
  address        String
  available      Boolean      @default(true)
  status         DoctorStatus @default(PENDING)
  appointments   Appointment[]
}

enum DoctorStatus {
  PENDING
  APPROVED
  REJECTED
}

model Appointment{
  id        String  @id @default(uuid())
  userId    String   
  user      User  @relation(fields :  [userId] , references : [id] , onDelete : Cascade)

  docId     String
  doctor    Doctor @relation(fields : [docId] , references : [userId] , onDelete : Cascade)

  fees      Float
  status    AppointmentStatus @default(PENDING)   
  date      DateTime

  createdAt DateTime    @default(now())  
}

enum AppointmentStatus{
  PENDING
  CANCELLED
  CONFIRMED
  COMPLETED
}